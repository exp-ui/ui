{
    "name": "@exp-ui/ui",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nama-org/ui.git"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "version": "0.1.0",
    "type": "module",
    "description": "UI component library internal kantor",
    "main": "./dist/index.umd.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.umd.cjs"
        },
        "./style.css": "./dist/ui.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "dev": "vite --config vite.playground.config.ts",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "peerDependencies": {
        "vue": "^3.4.0"
    },
    "dependencies": {
        "reka-ui": "^2.0.0"
    },
    "devDependencies": {
        "@storybook/addon-docs": "^10.5.0",
        "@storybook/addon-vitest": "^10.5.0",
        "@storybook/vue3-vite": "^10.5.0",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vitest/browser-playwright": "^4.1.10",
        "@vitest/coverage-v8": "^4.1.10",
        "autoprefixer": "^10.4.20",
        "playwright": "^1.61.1",
        "postcss": "^8.4.49",
        "react": "^18",
        "react-dom": "^18",
        "storybook": "^10.5.0",
        "tailwind-merge": "^2.6.0",
        "tailwindcss": "^3.4.17",
        "vite": "^6.1.0",
        "vite-plugin-dts": "^4.5.0",
        "vitest": "^4.1.10",
        "vitest-browser-vue": "^2.1.0",
        "vue": "^3.5.13",
        "vue-tsc": "^2.2.0"
    },
    "packageManager": "yarn@3.8.7+sha512.bbe7e310ff7fd20dc63b111110f96fe18192234bb0d4f10441fa6b85d2b644c8923db8fbe6d7886257ace948440ab1f83325ad02af457a1806cdc97f03d2508e"
